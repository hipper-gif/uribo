# サロンボード認証情報は Mneme credentials で一元管理（service_name: salonboard_neyagawa / salonboard_moriguchi）
# .env への SALONBOARD_* 直書きは廃止しました

# Nicolio API（通常は変更不要、デフォルトは本番）
# NICOLIO_API_URL=https://twinklemark.xsrv.jp/nicolio-api/api.php
# NICOLIO_API_TOKEN=nicolio_secret_2525xsrv

# Mneme API（サロンボード認証情報 + 給与計算で従業員情報取得）
# MNEME_API_URL=https://twinklemark.xsrv.jp/mneme-api/index.php
# MNEME_API_TOKEN=mneme_secret_2525xsrv
